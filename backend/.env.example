# BPERP Backend Environment Configuration
# Copy this file to .env and update with your values

# ===================
# Database Path
# ===================
# Path to the SQLite database file (local to this machine)
# When running on NAS: use a path like /home/user/bperp/bperp.db
# Local dev: ./bperp.db
DB_PATH=./bperp.db

# ===================
# Server Configuration
# ===================
PORT=3000
NODE_ENV=development

# ===================
# Session Settings
# ===================
# How long sessions remain valid (in hours)
SESSION_TIMEOUT_HOURS=24

# ===================
# Security
# ===================
# Comma-separated list of allowed origins for CORS
# Leave empty to allow all in development
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ===================
# Rate Limiting
# ===================
# Login attempts per 15-minute window
LOGIN_RATE_LIMIT=5

# API requests per minute
API_RATE_LIMIT=100
