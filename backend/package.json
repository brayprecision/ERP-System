{
  "name": "bperp-backend",
  "version": "1.0.0",
  "description": "BPERP - Business Process ERP Backend Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/middleware tests/utils",
    "test:integration": "jest tests/routes",
    "migrate": "node migrations/migrate.js up",
    "migrate:down": "node migrations/migrate.js down",
    "migrate:status": "node migrations/migrate.js status",
    "migrate:create": "node migrations/migrate.js create"
  },
  "keywords": [
    "erp",
    "inventory",
    "management"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "better-sqlite3": "^11.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.1.0",

    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
