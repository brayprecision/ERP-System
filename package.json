{
  "name": "bperp",
  "productName": "BPERP - Manufacturing ERP",
  "version": "1.0.0-beta.2",
  "description": "Internal manufacturing ERP for Bray Precision LLC - Inventory, Quotes, Work Orders, Tasks, and Maintenance",
  "main": "electron/main.js",
  "author": {
    "name": "Bray Precision LLC",
    "email": "support@brayprecision.com"
  },
  "license": "MIT AND Commons-Clause",
  "homepage": "https://brayprecision.com/bperp",
  "repository": {
    "type": "git",
    "url": "https://github.com/brayprecision/ERP-System.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "dev:backend": "cd backend && npm run dev",
    "build": "electron-builder",
    "rebuild:backend": "node scripts/rebuild-backend-native.js",
    "build:win": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --win --publish never",
    "build:linux": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --linux --publish never",
    "release:win": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --win --publish always",
    "release:linux": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --linux --publish always",
    "pack": "electron-builder --dir",
    "pack:win": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --win --dir --publish never",
    "pack:linux": "npm run backend:install:prod && npm run rebuild:backend && electron-builder --linux --dir --publish never",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf dist dist-installers",
    "backend:install": "cd backend && npm install",
    "backend:install:prod": "cd backend && npm install --omit=dev --no-audit --no-fund && npm prune --omit=dev",
    "backend:migrate": "cd backend && npm run migrate",
    "backend:test": "cd backend && npm test",
    "setup": "npm install && npm run backend:install"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "brayprecision",
      "repo": "ERP-System",
      "private": true
    },
    "appId": "com.brayprecision.bperp",
    "productName": "BPERP",
    "copyright": "Copyright © 2026 Bray Precision LLC",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-installers",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend/",
        "filter": [
          "**/*",
          "!tests/**",
          "!dist/**",
          "!.env*",
          "!**/*.ts",
          "!tsconfig.json"
        ]
      },
      {
        "from": "frontend/",
        "to": "frontend/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "electron/assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Bray Precision LLC"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BPERP",
      "menuCategory": "Business",
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets",
      "category": "Office",
      "maintainer": "Bray Precision LLC <support@brayprecision.com>",
      "vendor": "Bray Precision LLC",
      "synopsis": "Manufacturing ERP for small machine shops",
      "description": "BPERP is a complete ERP solution for machine shops, featuring inventory management, quote/work order tracking, task management, and maintenance scheduling.",
      "desktop": {
        "StartupNotify": "true",
        "Terminal": "false",
        "Type": "Application",
        "Categories": "Office;Database;ProjectManagement;"
      }
    },
    "deb": {
      "depends": [
        "ca-certificates",
        "libasound2 | libasound2t64",
        "libatk-bridge2.0-0 | libatk-bridge2.0-0t64",
        "libatk1.0-0 | libatk1.0-0t64",
        "libatspi2.0-0 | libatspi2.0-0t64",
        "libcairo2 | libcairo2t64",
        "libcups2 | libcups2t64",
        "libdbus-1-3",
        "libdrm2",
        "libexpat1",
        "libgbm1",
        "libglib2.0-0 | libglib2.0-0t64",
        "libgtk-3-0 | libgtk-3-0t64",
        "libnotify4",
        "libnspr4",
        "libnss3",
        "libpango-1.0-0 | libpango-1.0-0t64",
        "libsecret-1-0",
        "libudev1 | libudev1t64",
        "libuuid1 | libuuid1t64",
        "libx11-6",
        "libx11-xcb1",
        "libxcb1",
        "libxcomposite1",
        "libxdamage1",
        "libxext6",
        "libxfixes3",
        "libxkbcommon0",
        "libxrandr2",
        "libxshmfence1",
        "libxss1",
        "libxtst6",
        "xdg-utils"
      ],
      "priority": "optional",
      "compression": "xz"
    },
    "appImage": {
      "license": "LICENSE.txt"
    }
  }
}
