# BPERP Backend Environment Configuration
# Copy this file to .env and fill in values for your deployment.

# ===================
# Database Path
# ===================
# Path to the SQLite database file on the machine running this backend.
# The file must be LOCAL to this machine — do NOT point at a raw network share.
# WAL mode (.db-shm / .db-wal) requires local shared-memory support.
#
# Standalone mode (Electron forks the backend, single PC):
#   DB_PATH=./bperp.db
#
# Network mode (backend runs on NAS/server, workstations connect via HTTP):
#   Linux/macOS: DB_PATH=/srv/bperp/bperp.db
#   Windows:     DB_PATH=C:\bperp\bperp.db
DB_PATH=./bperp.db

# ===================
# Server
# ===================
PORT=3000
NODE_ENV=development

# ===================
# CORS
# ===================
# Controls which origins may call the API.
# Standalone mode: leave unset (defaults to * — only localhost connects anyway).
# Network mode: set to the URL(s) workstations use to reach this server.
#   Single origin:    CORS_ORIGIN=http://192.168.1.50:3000
#   Multiple origins: CORS_ORIGIN=http://192.168.1.50:3000,http://192.168.1.51:3000
# WARNING: leaving this unset in Network mode allows any LAN host to call the API.
CORS_ORIGIN=*
